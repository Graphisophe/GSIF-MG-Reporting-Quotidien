{
  "entities": {
    "Child": {
      "title": "Child",
      "description": "A child associated with a contact",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "birthDate": { "type": "string" },
        "requestedLevel": { "type": "string" }
      },
      "required": ["firstName", "birthDate", "requestedLevel"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact request for school registration",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "lastName": { "type": "string" },
        "fatherPhone": { "type": "string" },
        "motherPhone": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/entities/Child" }
        },
        "source": { "type": "string" },
        "channel": { "type": "string" },
        "interestLevel": { "type": "string" },
        "actionTaken": { "type": "string" },
        "appointmentDate": { "type": "string" },
        "status": { "type": "string" },
        "internalNotes": { "type": "string" },
        "sensitivePoints": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string", "description": "The UID of the user who created this contact" }
      },
      "required": ["date", "lastName", "children", "source", "channel", "interestLevel", "actionTaken", "status", "userId"]
    }
  },
  "firestore": {
    "contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Collection of all contact requests"
    }
  }
}
