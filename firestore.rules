rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: contacts
    // Document ID: auto-generated
    // Fields:
    //   - date: string (required)
    //   - lastName: string (required, < 100 chars)
    //   - fatherPhone: string (optional, < 20 chars)
    //   - motherPhone: string (optional, < 20 chars)
    //   - children: list of objects (required, max 10)
    //   - source: string (required, < 50 chars)
    //   - channel: string (required, < 50 chars)
    //   - interestLevel: string (required, < 50 chars)
    //   - actionTaken: string (required, < 50 chars)
    //   - appointmentDate: string (optional, < 50 chars)
    //   - status: string (required, < 50 chars)
    //   - internalNotes: string (optional, < 2000 chars)
    //   - sensitivePoints: string (optional, < 2000 chars)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - userId: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidList(listData, maxSize) {
      return listData is list && listData.size() <= maxSize;
    }

    function isValidContact(data) {
      return hasRequiredFields(['date', 'lastName', 'children', 'source', 'channel', 'interestLevel', 'actionTaken', 'status', 'userId']) &&
             validStringLength('date', 1, 50) &&
             validStringLength('lastName', 1, 100) &&
             isValidOptionalString('fatherPhone', 0, 20) &&
             isValidOptionalString('motherPhone', 0, 20) &&
             isValidList(data.children, 10) &&
             validStringLength('source', 1, 50) &&
             validStringLength('channel', 1, 50) &&
             validStringLength('interestLevel', 1, 50) &&
             validStringLength('actionTaken', 1, 50) &&
             isValidOptionalString('appointmentDate', 0, 50) &&
             validStringLength('status', 1, 50) &&
             isValidOptionalString('internalNotes', 0, 2000) &&
             isValidOptionalString('sensitivePoints', 0, 2000) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 50;
    }

    match /contacts/{contactId} {
      // Allow users to read their own contacts
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Allow users to create contacts if they set themselves as the owner
      allow create: if isAuthenticated() && 
                    isValidContact(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
                    
      // Allow users to update their own contacts
      allow update: if isAuthenticated() && 
                    isDocOwner() && 
                    isValidContact(request.resource.data) && 
                    uidNotModified();
                    
      // Allow users to delete their own contacts
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
